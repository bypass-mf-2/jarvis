[Unit]
Description=ChromaDB Vector Store
After=network.target

[Service]
Type=simple
User=jarvis
Group=jarvis
WorkingDirectory=/opt/jarvis-ai
ExecStart=/usr/local/bin/chroma run --path /opt/jarvis-ai/chroma-data --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=chromadb

[Install]
WantedBy=multi-user.target
